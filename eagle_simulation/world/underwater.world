<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="underwater_world">

    <scene>
      <ambient>0.2 1.0 1.0 1.0</ambient> <background>0.0 0.7 0.8 1.0</background>
    </scene>

    <physics name="1ms" type="dart">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>
    
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-buoyancy-system" name="gz::sim::systems::Buoyancy">
      <uniform_fluid_density>1025</uniform_fluid_density>
    </plugin>

    <model name='floor'>
      <static>true</static>
      <pose>0 0 -3 0 0 0</pose>
      <link name='link'>
        <visual name='v'>
          <geometry><box><size>50 25 3</size></box></geometry>
          <material>
            <diffuse>0.5 0.5 0.5 1</diffuse>
            <pbr>
              <metal>
                <albedo>0.5 0.5 0.5 1</albedo>
                <roughness>1.0</roughness>
              </metal>
            </pbr>
          </material>
        </visual>
      </link>
    </model>
    <model name='long_wall_1'>
      <static>true</static>
      <pose>0 -12.5 0 0 0 0</pose>
      <link name='link'>
        <visual name='v'>
          <geometry><box><size>50 1 3</size></box></geometry>
          <material>
            <diffuse>0.75 0.75 0.75 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
            <pbr>
              <metal>
                <albedo>0.75 0.75 0.75 1</albedo>
                <roughness>0.9</roughness>
              </metal>
            </pbr>
          </material>
        </visual>
      </link>
    </model>
    <model name='long_wall_2'>
      <static>true</static>
