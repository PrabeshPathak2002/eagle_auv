                <roughness>0.9</roughness>
              </metal>
            </pbr>
          </material>
        </visual>
        <collision name='c'>
          <geometry><box><size>50 1 3</size></box></geometry>
        </collision>
      </link>
    </model>
    <model name='wide_wall_1'>
      <static>true</static>
      <pose>25 0 0 0 0 1.57</pose>
      <link name='link'>
        <visual name='v'>
          <geometry><box><size>25 1 3</size></box></geometry>
          <material>
            <diffuse>0.75 0.75 0.75 1</diffuse>
