      <material><ambient>0 0 0 1</ambient></material></visual></link>
    </model>

    <light name='sun1' type='directional'><pose>0 0 10 0 0 0</pose><intensity>2.5</intensity><direction>-0.5 0.1 -0.9</direction></light>
    <light name='sun2' type='point'><pose>0 0 10 0 0 0</pose><intensity>2.0</intensity></light>
    
    <light name='gate_light_1' type='point'><pose>2.5 -2 2 0 0 0</pose><intensity>1.5</intensity></light>
